---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Contact Sadra Construction for a free kitchen or bathroom remodeling estimate in Los Angeles.">

  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content container">
      <p class="section-label" style="color:var(--brass-light)">Get In Touch</p>
      <h1>Contact Us</h1>
      <p>Let's discuss your vision. Free consultations, no obligation.</p>
    </div>
  </section>

  <section class="contact-section">
    <div class="container">
      <div class="contact-layout">
        <div class="contact-info">
          <p class="section-label">Reach Us</p>
          <h2>Let's Start the Conversation.</h2>
          <div class="divider"></div>
          <p>We serve homeowners throughout Greater Los Angeles and the San Fernando Valley. Call, email, or fill out the form and we'll be in touch within one business day.</p>

          <div class="info-items">
            <div class="info-item">
              <span class="info-icon">✆</span>
              <div>
                <span class="info-label">Phone</span>
                <a href="tel:3109226623" class="info-value">310.922.6623</a>
              </div>
            </div>
            <div class="info-item">
              <span class="info-icon">✉</span>
              <div>
                <span class="info-label">Email</span>
                <a href="mailto:david@sadraconstruction.com" class="info-value">david@sadraconstruction.com</a>
              </div>
            </div>
            <div class="info-item">
              <span class="info-icon">◎</span>
              <div>
                <span class="info-label">Service Area</span>
                <span class="info-value">Greater Los Angeles &<br/>The San Fernando Valley</span>
              </div>
            </div>
            <div class="info-item">
              <span class="info-icon">◷</span>
              <div>
                <span class="info-label">Hours</span>
                <span class="info-value">Mon – Sat: 8:00 AM – 6:00 PM</span>
              </div>
            </div>
          </div>

          <div class="contact-badge">
            <span class="badge-line">Licensed & Insured</span>
            <span class="badge-sep">·</span>
            <span class="badge-line">Greater Los Angeles, CA</span>
          </div>
        </div>


        <div class="contact-form-wrap">
          <h3>Request a Free Estimate</h3>

          <form
            class="contact-form"
            id="contactForm"
            action="https://api.web3forms.com/submit"
            method="POST"
          >
          <input type="hidden" name="access_key" value="3154c3e3-f3df-42e0-a0ae-91f6e26db4f9" />
          <input type="hidden" name="subject" value="New Estimate Request — Sadra Construction" />
          <input type="hidden" name="redirect" value="https://sadraconstruction.com/contact?success=true" />
            <input type="text" name="_gotcha" style="display:none" />

            <div class="form-row">
              <div class="form-group">
                <label for="firstName">First Name *</label>
                <input type="text" id="firstName" name="firstName" required placeholder="Jane" />
              </div>
              <div class="form-group">
                <label for="lastName">Last Name *</label>
                <input type="text" id="lastName" name="lastName" required placeholder="Smith" />
              </div>
            </div>
            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" required placeholder="jane@example.com" />
            </div>
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" placeholder="(310) 000-0000" />
            </div>
            <div class="form-group">
              <label for="city">City / Neighborhood</label>
              <input type="text" id="city" name="city" placeholder="Sherman Oaks, Encino, Brentwood..." />
            </div>
            <div class="form-group">
              <label for="service">Project Type *</label>
              <select id="service" name="service" required>
                <option value="" disabled selected>Select a service</option>
                <option value="Kitchen Remodel">Kitchen Remodel</option>
                <option value="Bathroom Remodel">Bathroom Remodel</option>
                <option value="Kitchen & Bathroom">Kitchen & Bathroom</option>
                <option value="Tile / Stonework">Tile / Stonework</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="budget">Approximate Budget</label>
              <select id="budget" name="budget">
                <option value="" disabled selected>Select a range</option>
                <option value="Under $25,000">Under $25,000</option>
                <option value="$25,000 – $50,000">$25,000 – $50,000</option>
                <option value="$50,000 – $100,000">$50,000 – $100,000</option>
                <option value="$100,000+">$100,000+</option>
                <option value="Not sure yet">Not sure yet</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Tell Us About Your Project</label>
              <textarea id="message" name="message" rows="5" placeholder="Describe your project, timeline, or any specific goals you have in mind..."></textarea>
            </div>
            <button type="submit" class="btn btn-filled submit-btn">Send My Request</button>
            <p class="form-note">* We typically respond within one business day.</p>
          </form>


          <div class="form-success" id="formSuccess" style="display:none">
            <span class="success-icon">✓</span>
            <h3>Message Received!</h3>
            <p>Thank you for reaching out. David will be in contact with you within one business day to discuss your project.</p>
            <a href="/contact" class="btn" style="margin-top:1.5rem">Send Another Message</a>
          </div>

        </div>
      </div>
    </div>
  </section>


  <section class="map-section">
    <div class="container">
      <div class="map-header">
        <p class="section-label">Where We Work</p>
        <h2>Proudly Serving Los Angeles</h2>
        <p>From the Westside to the Valley — Sherman Oaks, Encino, Tarzana, Woodland Hills, Brentwood, Santa Monica, Beverly Hills, Calabasas, Chatsworth, and throughout Greater Los Angeles.</p>
      </div>
    </div>

    <div class="map-embed">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d264169.47446442904!2d-118.52440785!3d34.10259435!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2sus!4v1709000000000!5m2!1sen!2sus"
        width="100%"
        height="500"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Sadra Construction service area — Greater Los Angeles and San Fernando Valley"
      ></iframe>
      <div class="map-pin-label">
        <span class="pin-dot"></span>
        Greater Los Angeles & San Fernando Valley Service Area
      </div>
    </div>
  </section>

</Layout>

<style>
.page-hero {
  position: relative;
  height: 55vh;
  min-height: 420px;
  display: flex;
  align-items: flex-end;
  padding-bottom: 4rem;
}
.page-hero-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #1a1a1a 0%, #3a3530 60%, #2a2520 100%);
}
.page-hero-overlay {
  position: absolute;
  inset: 0;
  background: rgba(44,44,44,0.5);
}
.page-hero-content { position: relative; z-index: 2; }
.page-hero-content h1 {
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  color: var(--warm-white);
  margin: 0.5rem 0;
}
.page-hero-content p { color: rgba(245,240,232,0.7); }


.contact-section { padding: 7rem 0; }
.contact-layout {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 6rem;
  align-items: start;
}
.contact-info h2 { font-size: clamp(1.6rem, 3vw, 2.4rem); }
.contact-info > p {
  font-size: 0.92rem;
  color: var(--charcoal-light);
  margin-bottom: 2.5rem;
}
.info-items {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}
.info-item { display: flex; gap: 1.25rem; align-items: flex-start; }
.info-icon {
  font-size: 1.1rem;
  color: var(--brass);
  width: 28px;
  flex-shrink: 0;
  margin-top: 2px;
}
.info-label {
  display: block;
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--brass);
  font-weight: 600;
  margin-bottom: 0.2rem;
}
.info-value {
  font-size: 0.92rem;
  color: var(--charcoal);
  line-height: 1.5;
}
a.info-value { transition: color 0.2s; }
a.info-value:hover { color: var(--brass); }

.contact-badge {
  display: inline-flex;
  gap: 0.75rem;
  align-items: center;
  border: 1px solid rgba(184,149,42,0.35);
  padding: 0.6rem 1.25rem;
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  color: var(--charcoal-light);
}
.badge-sep { color: var(--brass); }


.contact-form-wrap {
  background: var(--warm-white-2);
  padding: 3rem;
}
.contact-form-wrap > h3 {
  font-family: var(--font-display);
  font-size: 1.5rem;
  margin-bottom: 2rem;
  padding-bottom: 1.25rem;
  border-bottom: 1px solid rgba(184,149,42,0.2);
}
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}
.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
}
.form-group { display: flex; flex-direction: column; gap: 0.4rem; }
.form-group label {
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--charcoal-light);
}
.form-group input,
.form-group select,
.form-group textarea {
  background: var(--warm-white);
  border: 1px solid rgba(184,149,42,0.25);
  padding: 0.8rem 1rem;
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: var(--charcoal);
  outline: none;
  transition: border-color 0.2s;
  width: 100%;
  -webkit-appearance: none;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  border-color: var(--brass);
}
.form-group textarea { resize: vertical; min-height: 120px; }
.submit-btn { align-self: flex-start; margin-top: 0.5rem; }
.form-note {
  font-size: 0.75rem;
  color: var(--charcoal-light);
  margin-top: 0.25rem;
}


.form-success {
  text-align: center;
  padding: 3rem 2rem;
}
.success-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background: var(--brass);
  color: var(--warm-white);
  font-size: 1.5rem;
  margin-bottom: 1.5rem;
}
.form-success h3 { font-size: 1.8rem; margin-bottom: 1rem; }
.form-success p { font-size: 0.92rem; color: var(--charcoal-light); }


.map-section {
  background: var(--warm-white-2);
  padding-top: 6rem;
}
.map-header {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem 3rem;
}
.map-header h2 {
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  margin-bottom: 0.75rem;
}
.map-header p {
  font-size: 0.92rem;
  color: var(--charcoal-light);
  max-width: 680px;
}
.map-embed {
  position: relative;
  width: 100%;
}
.map-embed iframe {
  display: block;
  filter: saturate(0.85) contrast(1.05);
}
.map-pin-label {
  position: absolute;
  bottom: 1.5rem;
  left: 50%;
  transform: translateX(-50%);
  background: var(--charcoal);
  color: var(--warm-white);
  font-size: 0.72rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 0.6rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  white-space: nowrap;
}
.pin-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--brass);
  flex-shrink: 0;
}

@media (max-width: 900px) {
  .contact-layout { grid-template-columns: 1fr; gap: 3rem; }
  .form-row { grid-template-columns: 1fr; }
  .map-pin-label { display: none; }
}
</style>

<script>
  const params = new URLSearchParams(window.location.search);
  if (params.get('success') === 'true') {
    const form = document.getElementById('contactForm');
    const success = document.getElementById('formSuccess');
    if (form && success) {
      form.style.display = 'none';
      success.style.display = 'block';
    }
  }
</script>